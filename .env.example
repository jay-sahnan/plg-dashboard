# =============================================================================
# PLG Dashboard — environment variables
# =============================================================================
# Copy this file to `.env.local` (gitignored) and fill in only what you use.
# The `/onboard` agent fills these in for you as it wires each source — you
# rarely need to edit this by hand. Nothing here is required to run the demo;
# with no keys set, every chart falls back to the fabricated data in mock/data.ts.
# =============================================================================

# --- Data source (filled in during /onboard) --------------------------------
# Where your real metrics live. Most people just have their app database — point
# DATABASE_URL at it and the agent writes SQL to compute the charts. You only
# need the source(s) you actually use; delete the rest.

# Raw app DB / warehouse (Supabase, Postgres, Neon, RDS, …)
# DATABASE_URL="postgres://user:pass@host:5432/dbname"

# Local SQLite (zero credentials, nothing to host) — the simplest local source.
# Read via Node's built-in node:sqlite (no dependency). See lib/sources/example.ts.
# SQLITE_DB_PATH="./data/app.db"

# Product analytics (only if you pull metrics from here instead of a DB)
# POSTHOG_API_KEY=""
# POSTHOG_HOST="https://us.posthog.com"
# POSTHOG_PROJECT_ID=""

# Data warehouse SDKs (only if used)
# SNOWFLAKE_ACCOUNT=""
# SNOWFLAKE_USER=""
# SNOWFLAKE_PASSWORD=""
# SNOWFLAKE_WAREHOUSE=""
# SNOWFLAKE_DATABASE=""
# BIGQUERY_PROJECT_ID=""
# GOOGLE_APPLICATION_CREDENTIALS=""

# --- "What shipped & signals" panel -----------------------------------------
# Right-hand timeline. Wire only the sources you want; each is optional.

# Slack (shipping announcements / signals from chosen channels)
# SLACK_BOT_TOKEN="xoxb-..."
# SLACK_CHANNEL_IDS="C0123,C0456"

# Linear (completed / shipped issues)
# LINEAR_API_KEY="lin_api_..."

# GitHub (releases or merged PRs as "what shipped")
# GITHUB_TOKEN="ghp_..."
# GITHUB_REPO="owner/repo"

# --- AI Insights -------------------------------------------------------------
# Real Claude analysis in the Insights panel (otherwise it serves canned text).
# ANTHROPIC_API_KEY="sk-ant-..."

# --- Browserbase (optional / experimental) -----------------------------------
# Only if you opt into auto-discovering external news/changelog/brand mentions.
# BROWSERBASE_API_KEY=""
# BROWSERBASE_PROJECT_ID=""

# --- Deployment (Vercel) -----------------------------------------------------
# Goals are written to goals.json on disk locally. On serverless that file is
# read-only, so a deployed dashboard needs a real store (the agent sets this up
# in Phase 4). Example for Vercel KV / Upstash Redis:
# KV_REST_API_URL=""
# KV_REST_API_TOKEN=""

# --- Hex (optional — remove if unused) ---------------------------------------
# Leftover scaffolding from the original build. Most clones do NOT use Hex; the
# /onboard agent offers to delete app/api/hex-embed/route.ts and these vars.
# HEX_API_TOKEN=""
# HEX_PLG_PROJECT_ID=""
# HEX_ACTIVATION_PROJECT_ID=""
# HEX_BASE_URL="https://app.hex.tech/api/v1"
